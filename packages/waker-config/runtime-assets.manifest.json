{
  "description": "Runtime asset manifest for @workspaces-team/waker-config. The training package carries its own runtime so browser-side tiny-head training works without depending on @workspaces-team/waker-web at install time.",
  "policies": [
    {
      "policy": "single_word_only",
      "cohortId": "2026-04-16-cohort-adapter-official-first-run-single-word-registration-v1",
      "runtimeDir": "single-word-only"
    }
  ],
  "compatibilityBackbone": {
    "weightsBinary": "rust/sdk-wasm/model/backbone_16k.bin",
    "manifestJson": "rust/sdk-wasm/model/backbone_16k_manifest.json",
    "destinationModelPath": "backbone/model.bin",
    "destinationManifestPath": "backbone/model_manifest.json"
  },
  "copyContract": {
    "fromDeliverableBundle": [
      "registration.json",
      "runtime-config.json",
      "policy.json",
      "bundle.manifest.json",
      "frontend.json",
      "registration/**"
    ],
    "rewrittenForBrowserRuntime": [
      "registration.json",
      "runtime-config.json",
      "bundle.manifest.json",
      "registration/*/detector.json"
    ]
  }
}
